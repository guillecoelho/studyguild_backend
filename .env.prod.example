# Copy to .env.prod and fill in real values. Never commit .env.prod.
DEBUG=False
SECRET_KEY=change-me-generate-long-random-string
ALLOWED_HOSTS=studyguild.example.com,localhost
CORS_ALLOWED_ORIGINS=https://studyguild.example.com

POSTGRES_DB=studyguild
POSTGRES_USER=studyguild
POSTGRES_PASSWORD=change-me-strong-password

# Local filesystem storage (served by nginx from media_data volume).
# Set USE_S3_STORAGE=True only if you want S3/minio offload.
USE_S3_STORAGE=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=
